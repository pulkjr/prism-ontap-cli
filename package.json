{
  "name": "prism-ontap-cli",
  "version": "1.0.0",
  "description": "Prism.js language definition for NetApp ONTAP 9.x CLI syntax highlighting",
  "type": "module",
  "main": "src/prism-ontap-cli.cjs",
  "module": "src/prism-ontap-cli.js",
  "exports": {
    ".": {
      "import": "./src/prism-ontap-cli.js",
      "require": "./src/prism-ontap-cli.cjs",
      "default": "./src/prism-ontap-cli.cjs"
    },
    "./themes/dark": "./themes/prism-ontap-dark.css",
    "./themes/light": "./themes/prism-ontap-light.css"
  },
  "files": [
    "src/",
    "standalone/",
    "themes/",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "eslint src/ standalone/"
  },
  "keywords": [
    "prism",
    "prismjs",
    "syntax-highlighting",
    "ontap",
    "netapp",
    "cli",
    "docusaurus"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "prismjs": ">=1.27.0"
  },
  "peerDependenciesMeta": {
    "prismjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prismjs": "^1.29.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pulkjr/prism-ontap-cli.git"
  },
  "bugs": {
    "url": "https://github.com/pulkjr/prism-ontap-cli/issues"
  },
  "homepage": "https://github.com/pulkjr/prism-ontap-cli#readme"
}
